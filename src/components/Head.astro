---
// Global head component - add to all pages
// GSC verification and analytics tracking
---

<!-- Google Search Console Verification -->
<!-- Replace content value after GSC setup -->
<meta name="google-site-verification" content="REPLACE_WITH_GSC_TOKEN" />

<!-- Umami Analytics (privacy-friendly, no cookies) -->
<!-- Replace data-website-id after Umami setup -->
<script defer src="https://cloud.umami.is/script.js" data-website-id="REPLACE_WITH_UMAMI_ID"></script>

<!-- Affiliate link click tracking -->
<script>
document.addEventListener('click', function(e) {
  const link = e.target.closest('a[rel*="sponsored"]');
  if (link && window.umami) {
    window.umami.track('affiliate-click', {
      tool: link.textContent.trim(),
      url: link.href,
      page: window.location.pathname
    });
  }
});
</script>
